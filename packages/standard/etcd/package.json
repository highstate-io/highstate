{
  "name": "@highstate/etcd",
  "version": "0.20.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./units/connection": "./dist/units/connection/index.js",
    "./units/namespace": "./dist/units/namespace/index.js",
    ".": {
      "default": "./dist/shared/index.js",
      "types": "./src/shared/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "nx": {
    "tags": [
      "stdlib"
    ]
  },
  "scripts": {
    "build": "highstate build",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "biome": "biome check --write --unsafe --error-on-warnings",
    "biome:check": "biome check --error-on-warnings",
    "generate-sdks": "./scripts/generate-sdks.sh"
  },
  "dependencies": {
    "@highstate/common": "workspace:*",
    "@highstate/contract": "workspace:*",
    "@highstate/etcd-sdk": "workspace:*",
    "@highstate/library": "workspace:*",
    "@highstate/pulumi": "workspace:*",
    "@pulumi/pulumi": "3.232.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@highstate/cli": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev.20250920.1"
  },
  "repository": {
    "url": "https://github.com/highstate-io/highstate"
  }
}
